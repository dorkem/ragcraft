# ===========================
# CLOVA Studio (NCP)
# ===========================
CLOVA_STUDIO_API_KEY=your_clova_studio_api_key
CLOVA_STUDIO_ENDPOINT=https://clovastudio.stream.ntruss.com

# LLM 모델 선택
# 선택지: HCX-007 | HCX-005 | HCX-DASH-002 | HCX-003
HYPERCLOVA_MODEL=HCX-DASH-002

# 임베딩 모델
CLOVA_EMBEDDING_MODEL=bge-m3

# 리랭커 사용 여부
CLOVA_RERANKER_ENABLED=true

# ===========================
# 파서 선택
# 선택지: pymupdf4llm | pymupdf | tensorlake
# ===========================
PARSER_TYPE=pymupdf4llm

# ===========================
# Tensorlake (PARSER_TYPE=tensorlake 일 때만 필요)
# ===========================
TENSORLAKE_API_KEY=your_tensorlake_api_key

# ===========================
# ChromaDB
# ===========================
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=ragcraft

# ===========================
# 청킹 설정
# ===========================
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ===========================
# LangSmith 트레이싱 (선택)
# ===========================
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langsmith_api_key
LANGCHAIN_PROJECT=ragcraft
